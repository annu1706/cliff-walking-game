import numpy as np
import matplotlib.pyplot as plt
import gymnasium as gym


sarsa_rewards = np.load("sarsa_rewards.npy")
q_rewards = np.load("q_rewards.npy")

print("SARSA Episodes :", len(sarsa_rewards))
print("Q-Learning Episodes :", len(q_rewards))


plt.figure(figsize=(12,6))

plt.plot(sarsa_rewards, label="SARSA")
plt.plot(q_rewards, label="Q-Learning")

plt.title("Episode Reward Comparison")
plt.xlabel("Episode")
plt.ylabel("Reward")

plt.grid(True)
plt.legend()

plt.show()


window = 20

sarsa_avg = np.convolve(
    sarsa_rewards,
    np.ones(window)/window,
    mode="valid"
)

q_avg = np.convolve(
    q_rewards,
    np.ones(window)/window,
    mode="valid"
)

plt.figure(figsize=(12,6))

plt.plot(sarsa_avg, label="SARSA")
plt.plot(q_avg, label="Q-Learning")

plt.title("Moving Average Reward")
plt.xlabel("Episode")
plt.ylabel("Average Reward")

plt.grid(True)
plt.legend()

plt.show()


print("="*40)
print("SARSA")
print("="*40)

print("Average Reward :", np.mean(sarsa_rewards))
print("Maximum Reward :", np.max(sarsa_rewards))
print("Minimum Reward :", np.min(sarsa_rewards))

print()

print("="*40)
print("Q-LEARNING")
print("="*40)

print("Average Reward :", np.mean(q_rewards))
print("Maximum Reward :", np.max(q_rewards))
print("Minimum Reward :", np.min(q_rewards))


print("="*50)

if np.mean(sarsa_rewards) > np.mean(q_rewards):
    print("🏆 SARSA performed better on average.")
elif np.mean(sarsa_rewards) < np.mean(q_rewards):
    print("🏆 Q-Learning performed better on average.")
else:
    print("🤝 Both algorithms performed similarly.")

print("="*50)


import pandas as pd

comparison = pd.DataFrame({
    "Metric": [
        "Average Reward",
        "Maximum Reward",
        "Minimum Reward"
    ],
    "SARSA": [
        np.mean(sarsa_rewards),
        np.max(sarsa_rewards),
        np.min(sarsa_rewards)
    ],
    "Q-Learning": [
        np.mean(q_rewards),
        np.max(q_rewards),
        np.min(q_rewards)
    ]
})

comparison


sarsa_avg = np.mean(sarsa_rewards)
q_avg = np.mean(q_rewards)

print(f"SARSA Average Reward: {sarsa_avg:.2f}")
print(f"Q-Learning Average Reward: {q_avg:.2f}")

if q_avg > sarsa_avg:
    print("🏆 Q-Learning performed better in this experiment.")
elif sarsa_avg > q_avg:
    print("🏆 SARSA performed better in this experiment.")
else:
    print("🤝 Both algorithms performed similarly.")



